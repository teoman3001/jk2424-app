const miles = document.getElementById('miles').value;
const estimated = document.getElementById('total').value;

const payload = {
  pickup_address: document.getElementById('pickup').value,
  extra_stop:     document.getElementById('stop').value || null,
  dropoff_address:document.getElementById('dropoff').value,
  date:           document.getElementById('date').value,
  time:           document.getElementById('time').value,
  ampm:           document.getElementById('ampm').value,
  miles:          miles ? parseFloat(miles) : null,
  price_total:    estimated ? parseFloat(estimated) : null,   // ⭐ ÖNEMLİ
  name:           document.getElementById('name').value,
  phone:          document.getElementById('phone').value,
  email:          document.getElementById('email').value,
  notes:          document.getElementById('notes').va<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>JK2424 – Instant Quote</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    body { background:#000; color:#f5f5f5; font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif; }
    .wrap { max-width:480px; margin:40px auto; padding:20px; background:#111; border-radius:16px; border:1px solid #333; }
    h1 { color:#D4AF37; margin-bottom:8px; }
    label { display:block; margin-top:8px; font-size:14px; }
    input, textarea { width:100%; padding:8px 10px; margin-top:2px; border-radius:10px; border:1px solid #444; background:#050505; color:#f5f5f5; }
    button { margin-top:12px; width:100%; padding:10px; border-radius:12px; border:none; background:#D4AF37; font-weight:700; }
    .msg { margin-top:10px; font-size:14px; }
  </style>
</head>
<body>
  <div class="wrap">
    <h1>JK2424 Booking</h1>
    <p>Fill in the details and request a reservation.</p>

    <label>Pickup address
      <input id="pickup" type="text" placeholder="Tysons, VA" />
    </label>

    <label>Extra stop (optional)
      <input id="stop" type="text" placeholder="Optional" />
    </label>

    <label>Drop-off address
      <input id="dropoff" type="text" placeholder="Dulles Airport" />
    </label>

    <label>Date (YYYY-MM-DD)
      <input id="date" type="text" placeholder="2025-11-25" />
    </label>

    <label>Time (HH:MM)
      <input id="time" type="text" placeholder="03:00" />
    </label>

    <label>AM / PM
      <input id="ampm" type="text" placeholder="AM or PM" />
    </label>

    <label>Miles (optional – şimdilik elle)
      <input id="miles" type="text" placeholder="40.07" />
    </label>

    <label>Estimated total ($ – optional)
      <input id="total" type="text" placeholder="143.93" />
    </label>

    <label>Your name
      <input id="name" type="text" placeholder="Teoman Deveci" />
    </label>

    <label>Mobile phone
      <input id="phone" type="text" placeholder="+1 771 217 3111" />
    </label>

    <label>Email
      <input id="email" type="email" placeholder="you@example.com" />
    </label>

    <label>Notes
      <textarea id="notes" rows="3" placeholder="Gate code, luggage, etc."></textarea>
    </label>

    <button id="sendBtn">Send Reservation Request</button>
    <div id="msg" class="msg"></div>
  </div>

  <script>
    document.getElementById('sendBtn').addEventListener('click', async () => {
      const payload = {
        pickup:        document.getElementById('pickup').value,
        stop:          document.getElementById('stop').value,
        dropoff:       document.getElementById('dropoff').value,
        rideDate:      document.getElementById('date').value,
        rideTime:      document.getElementById('time').value,
        ampm:          document.getElementById('ampm').value,
        miles:         document.getElementById('miles').value,
        total:         document.getElementById('total').value,
        customerName:  document.getElementById('name').value,
        customerPhone: document.getElementById('phone').value,
        customerEmail: document.getElementById('email').value,
        notes:         document.getElementById('notes').value,
      };

      const msgEl = document.getElementById('msg');
      msgEl.textContent = 'Gönderiliyor...';

      try {
        const res = await fetch('/api/bookings', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        const data = await res.json();
        if (data.ok) {
          msgEl.textContent = 'Rezervasyon isteğin alındı. En kısa sürede onaylayacağım.';
        } else {
          msgEl.textContent = 'Bir hata oluştu, lütfen tekrar dene.';
        }
      } catch (e) {
        msgEl.textContent = 'Sunucuya ulaşılamıyor.';
      }
    });
  </script>
</body>
</html>

